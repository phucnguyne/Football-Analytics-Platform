# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS - URL của web app (Next.js)
WEB_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_db?schema=public"

# Realtime service (Socket.io server) - dùng để api gọi sang khi cần emit event
REALTIME_INTERNAL_URL=http://localhost:3002
# Secret dùng để xác thực request nội bộ giữa api -> realtime (không phải JWT của user)
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string
