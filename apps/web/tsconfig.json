{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*":            ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*":        ["./src/lib/*"],
      "@/lib":          ["./src/lib/UtilsBarrel"],
      "@/hooks/*":      ["./src/hooks/*"],
      "@/hooks":        ["./src/hooks/HooksBarrel"],
      "@/store/*":      ["./src/store/*"],
      "@/store":        ["./src/store/StoreBarrel"],
      "@/types":        ["./src/types/TypesBarrel.ts"],
      "@/types/*":      ["./src/types/*"],
      
      "@/config/*":     ["./src/config/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}